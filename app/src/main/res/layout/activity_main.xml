<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sand_bg"
    tools:context=".MainActivity">

    <!-- ── 紧凑工具栏 ─────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbarCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="6dp">

            <!-- 导入按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/importButton"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="导入"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_upload" />

            <!-- 清空按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="清空"
                app:cornerRadius="12dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:background="@color/card_stroke" />

            <!-- 视图切换：网格 / 列表 -->
            <ImageButton
                android:id="@+id/gridViewButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="网格"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="@color/deep_green" />

            <ImageButton
                android:id="@+id/listViewButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="列表"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/deep_green" />

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@color/card_stroke" />

            <!-- 图标大小：S / M / L -->
            <TextView
                android:id="@+id/sizeSmallButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="S"
                android:textColor="@color/deep_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/sizeMediumButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="M"
                android:textColor="@color/deep_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/sizeLargeButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="L"
                android:textColor="@color/deep_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- 弹性空间 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- 状态文字（导入进度等） -->
            <TextView
                android:id="@+id/countText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>



    <!-- ── 空状态 ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:text="@string/empty_message"
        android:textColor="@color/text_muted"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarCard" />

    <!-- ── 视频列表 ──────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/videoRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="32dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarCard"
        app:spanCount="2"
        tools:listitem="@layout/item_video_card" />

</androidx.constraintlayout.widget.ConstraintLayout>
